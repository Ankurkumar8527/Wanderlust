<% layout("layouts/boilerplate") -%>
    <div class="row mt-3">
        <div class="col-8 offset-2" >
            <h3>Create a New Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" >
        <div class="mb-3">
            <label for="name" class="form-label">Title</label>
            <input name="listing[title]"
            type="text"
            placeholder="Add catchy title"
            class="form-control"
            required>
            <div class="invalid-feedback"> Title required</div>
        </div>

         <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]"
            type="text"
            placeholder="enter description"
             class="form-control"
             required></textarea>
             <div class="invalid-feedback"> Description required</div>
        </div>

         <div class="mb-3">
            <label for="image" class="form-label">Image Link</label>
            <input name="listing[image]"
            type="text"
            placeholder="enter url/Link" 
            class="form-control">
            
        </div>

        <div class="row">
            <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]" 
            type="text" 
            placeholder="1200" 
            class="form-control"
            required>
            <div class="invalid-feedback"> Enter Price </div>
        </div>

         <div class="mb-3 col-md-8">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" 
            type="text" 
            placeholder="Ghazibad" 
            class="form-control"
            required>
            <div class="invalid-feedback"> Location required</div>
        </div>
        </div>

         <div class="mb-3">
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" 
            type="text" 
            placeholder="India" 
            class="form-control"
            required>
            <div class="invalid-feedback"> Country name required</div>
        </div>

        <button class="btn btn-dark add-btn mt-3">Add</button>
    </form>
    </div>
</div>