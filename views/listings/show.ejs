<% layout("layouts/boilerplate") -%>
<body>

    <div class="row">
        <div class="col-8 offset-2">

    
    <h3 class="offset-3">Listing Details</h3>

    <div class="card col-6 offset-2 mt-3 show-card offset-3" >

        <img src=" <%=listing.image%>"
             alt="listing_image"
             class="card-img-top show-img"/>

        <div class="card-body">
            <p class="card-text"> 
            <b><%=listing.title %></b>
            <br> <br>
            <%=listing.description %> <br>
            &#8377; <%=listing.price.toLocaleString("en-In")%> <br>
            <%=listing.location %>  <br>
            <%=listing.country %> 
            </p>
        </div>
        </div>
    </div>


    <div class="btns">
        <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark col-1 offset-4 ">Edit</a> 
    <br> 
    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" class="col-1" >
        <button class="btn btn-dark offset-1">
            Delete 
        </button>
    </form> 
    </div>

</div>
    <br>
    <button class="btn btn-dark btn-primary"> <a href="/listings" class="text-decoration-none" >Home</a></button>
</body>
